# =========================================
# Server Configuration
# =========================================
PORT=5000
NODE_ENV=development

# =========================================
# Database Configuration (PostgreSQL)
# =========================================
# Local:   DB_HOST=localhost
# Render:  -> Use DATABASE_URL (exposed by Render managed DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobportal
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# =========================================
# JWT Configuration
# =========================================
# Use a strong random secret in production
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# =========================================
# Redis Configuration
# =========================================
# Local:   REDIS_HOST=localhost
# Render:  set from your Redis Upstash/Render Redis add-on
REDIS_HOST=localhost
REDIS_PORT=6379

# =========================================
# Email Configuration (SMTP)
# =========================================
# Local:  smtp.gmail.com with App Password
# Render: same, or use a service like SendGrid/Mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# =========================================
# CORS & Frontend URL
# =========================================
# Local:  http://localhost:3000
# Vercel: https://talentsphere-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# =========================================
# OAuth Configuration
# =========================================
# Create credentials at:
#   Google:  https://console.cloud.google.com/apis/credentials
#   GitHub:  https://github.com/settings/developers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =========================================
# File Upload Configuration
# =========================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# =========================================
# AI Service URL
# =========================================
# Local:  http://localhost:8000
# Render: https://talentsphere-ai.onrender.com
AI_SERVICE_URL=http://localhost:8000
